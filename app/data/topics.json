      "decisionFlow": [
        {
          "id": "start",
          "question": "Is airway compromised?",
          "options": [
            { "label": "Yes", "next": "airway_manage" },
            { "label": "No", "next": "stabilize" }
          ]
        },
        {
          "id": "airway_manage",
          "action": "Suction upper pouch, position upright, call anesthesia support now."
        },
        {
          "id": "stabilize",
          "question": "Is oxygen saturation below 92%?",
          "options": [
            { "label": "Yes", "next": "oxygen_path" },
            { "label": "No", "next": "iv_path" }
          ]
        },
        {
          "id": "oxygen_path",
          "action": "Start oxygen, monitor blood gases, reassess in 5 minutes."
        },
        {
          "id": "iv_path",
          "action": "Warm baby, start IV fluids with electrolytes, keep NPO."
        }
      ],
      "steps": [
        {
          "title": "Airway",
          "detail": "Position 30-45 degrees upright and maintain continuous upper pouch suction.",
          "resourceLimited": "Use frequent manual suction every 5-10 minutes if Replogle tube unavailable."
        },
        {
          "title": "Fluids",
          "detail": "Start isotonic IV fluids with glucose and electrolyte correction.",
          "resourceLimited": "Use available crystalloid and monitor urine output closely."
        },
        {
          "title": "Positioning",
          "detail": "Avoid supine position to reduce aspiration risk.",
          "resourceLimited": "Keep head elevated with rolled towel support if no pediatric bed wedge."
        }
      ],
      "investigations": ["Echocardiography", "Renal ultrasound", "Blood gases"],
      "risks": ["Aspiration pneumonia", "Sepsis", "Hypothermia"],
      "pearls": ["Stabilize before transfer", "Continuous suction prevents aspiration"],
      "pitfalls": ["Rushing to surgery", "Ignoring thermal regulation"],
      "mnemonic": "WARM: Warmth, Airway, Replogle, Metabolic support",
      "parentExplanation": "Your baby needs careful stabilization first so surgery is safer and recovery is smoother.",
      "mentorTip": "If airway risk is unclear, treat as high risk until proven otherwise."
